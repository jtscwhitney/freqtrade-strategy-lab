.mypy_cache/
.ruff_cache/

# Cursor — keep rules, ignore local noise
.cursorignore
.cursorindexingignore
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# OS
.DS_Store
Thumbs.db
